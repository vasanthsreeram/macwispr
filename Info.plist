<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>MacWispr</string>
    <key>CFBundleDisplayName</key>
    <string>MacWispr</string>
    <key>CFBundleIdentifier</key>
    <string>com.vasanthsreeram.macwispr</string>
    <key>CFBundleVersion</key>
    <string>1.2.1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.2.1</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>MacWispr</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
    <key>LSUIElement</key>
    <true/>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSMicrophoneUsageDescription</key>
    <string>MacWispr needs microphone access for voice dictation (on-device or with your own cloud API keys).</string>

    <!-- Sparkle auto-updates (https://sparkle-project.org/) -->
    <key>SUFeedURL</key>
    <string>https://fuckwisprflow.com/appcast.xml</string>
    <!--
      SUPublicEDKey: PLACEHOLDER — replace with the public key printed by Sparkle
      `generate_keys` (one-time). The matching private key must NEVER be committed;
      keep it in Keychain / secrets manager only. See docs/SPARKLE.md.
    -->
    <key>SUPublicEDKey</key>
    <string>PLACEHOLDER_REPLACE_WITH_generate_keys_PUBLIC_OUTPUT</string>
    <key>SUEnableAutomaticChecks</key>
    <true/>
</dict>
</plist>
